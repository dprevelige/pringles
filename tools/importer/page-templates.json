        {
          "id": "section-3-promo",
          "name": "Promotional Tiles Section",
          "selector": ".cmp-experiencefragment--promo-tiles",
          "style": "brand-red",
          "blocks": ["columns"],
          "defaultContent": []
        }
      ]
    }
  ]
